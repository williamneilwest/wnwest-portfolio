# -------------------------
# 🔁 COMMON BLOCKS
# -------------------------

(block_common) {
	@blocked_ips remote_ip 185.177.72.50
	handle @blocked_ips {
		abort
	}
}

(infra_service) {
	import block_common
}

# -------------------------
# 🌐 WORK DOMAIN (PUBLIC)
# -------------------------

work.westos.dev {
	import block_common

	handle /api/* {
		reverse_proxy backend:5000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /flows/* {
		reverse_proxy backend:5000
	}

	handle /uploads* {
		reverse_proxy backend:5000
	}

	handle /kb* {
		reverse_proxy backend:5000
	}

	handle /webhooks/* {
		reverse_proxy backend:5000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle {
		reverse_proxy frontend:5173
	}
}

# -------------------------
# 🔐 MAIN APP
# -------------------------

westos.dev {
	import block_common

	handle /ws/terminal {
		reverse_proxy terminal-service:3001
	}

	handle /api/* {
		reverse_proxy backend:5000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /flows/* {
		reverse_proxy backend:5000
	}

	handle /uploads* {
		reverse_proxy backend:5000
	}

	handle /kb* {
		reverse_proxy backend:5000
