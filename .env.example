WESTOS_DOMAIN=westos.dev
WORK_DOMAIN=work.westos.dev
AUTH_USER=
AUTH_PASS=
AUTH_SESSION_SECRET=change-me

CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=

BACKEND_PORT=5000
AI_GATEWAY_PORT=5001

BACKEND_FLASK_ENV=production
BACKEND_GUNICORN_BIND=0.0.0.0:5000
BACKEND_APP_NAME=westOS API
BACKEND_DATA_DIR=/app/data
POSTGRES_DB=westos
POSTGRES_USER=will
# Docker secret path used by backend/postgres in compose:
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# Optional local dev fallback only (no Docker secrets):
# POSTGRES_PASSWORD=

AI_FLASK_ENV=production
AI_GUNICORN_BIND=0.0.0.0:5001
AI_GUNICORN_TIMEOUT=180
AI_GUNICORN_GRACEFUL_TIMEOUT=30
AI_APP_NAME=westOS AI Gateway
LITELLM_MODEL=openai/gpt-4o
LITELLM_TEMPERATURE=0.2
OPENAI_MODEL=gpt-4o
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_HARD_TOKEN_CAP=20000
OPENAI_TEMPERATURE=0.2
AI_ANALYSIS_ENABLED=true
ENABLE_WEIGHTED_MATCHING=false
# Ollama disabled - OpenAI only
OLLAMA_API_BASE=
OLLAMA_MODEL=
USE_AI_GATEWAY=true
ACTIVE_TICKETS_PATH=/data/active_tickets.csv

POWER_AUTOMATE_GROUP_SEARCH_URL=
POWER_AUTOMATE_GROUP_SCRIPT_NAME=Search Groups
POWER_AUTOMATE_USER_GROUPS_SCRIPT_NAME=Get User Groups
POWER_AUTOMATE_GROUP_TIMEOUT_SECONDS=15
